# nanobot-docker Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Must be set
# ===========================================

# LLM Provider API Key (Minimax, OpenAI, etc.)
NANOBOT_API_KEY_PROVIDER=your_llm_api_key_here

# WebBridge API Key (for frontend authentication)
NANOBOT_API_KEY=your_webbridge_api_key_here

# ===========================================
# LLM PROVIDER (Optional)
# ===========================================

# Provider: minimax, openai, anthropic, etc.
NANOBOT_PROVIDER=minimax

# Model to use
NANOBOT_MODEL=minimax/MiniMax-M2.7-highspeed

# API Base URL (leave default for Minimax)
NANOBOT_API_BASE=https://api.minimax.io/v1

# ===========================================
# WEBBRIDGE (Optional)
# ===========================================

# HMAC secret for message signing (optional, leave empty to disable)
NANOBOT_HMAC_SECRET=

# IP whitelist (null = any IP allowed)
NANOBOT_ALLOWED_IP_NULL=null

# ===========================================
# OPTIONAL PARAMETERS
# ===========================================

# Max tokens per response
NANOBOT_MAX_TOKENS=8192

# Temperature (0.0 to 1.0)
NANOBOT_TEMPERATURE=0.1

# Agent display name
AGENT_NAME=Nanobot
