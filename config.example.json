{
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot/workspace",
      "model": "minimax/MiniMax-M2.7-highspeed",
      "provider": "minimax",
      "maxTokens": 8192,
      "contextWindowTokens": 196000,
      "temperature": 0.1,
      "maxToolIterations": 40
    }
  },
  "channels": {
    "webbridge": {
      "enabled": true,
      "host": "0.0.0.0",
      "port": 18791,
      "hmac_secret": "",
      "allowed_connections": [
        {
          "api_key": "CHANGE_THIS_TO_YOUR_API_KEY",
          "ip": null
        }
      ]
    }
  },
  "providers": {
    "minimax": {
      "apiKey": "YOUR_MINIMAX_API_KEY",
      "apiBase": "https://api.minimax.io/v1"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  }
}
